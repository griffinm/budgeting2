<h1 style="color: #212529; font-size: 24px; margin-bottom: 8px;">Daily Financial Report</h1>
<p style="color: #495057; font-size: 16px;">Hi <%= @user.first_name %>,</p>
<p style="color: #495057; font-size: 16px; margin-bottom: 24px;">Here is your daily financial summary for <%= @today.strftime('%B %d, %Y') %>.</p>

<%# Monthly Summary %>
<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #f8f9fa; border-radius: 8px; padding: 20px;">
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td width="50%" style="padding: 8px; vertical-align: top;">
            <div style="color: #868e96; font-size: 12px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">Profit This Month</div>
            <div style="color: <%= @profit_this_month >= 0 ? '#2f9e44' : '#e03131' %>; font-size: 28px; font-weight: 700;">
              <%= format_dollars(@profit_this_month) %>
            </div>
          </td>
          <td width="50%" style="padding: 8px; vertical-align: top;">
            <div style="color: #868e96; font-size: 12px; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px;">Spending vs Average</div>
            <div style="color: <%= @expense_percent_change <= 0 ? '#2f9e44' : '#e03131' %>; font-size: 28px; font-weight: 700;">
              <%= raw(@expense_percent_change >= 0 ? '&#9650;' : '&#9660;') %> <%= @expense_percent_change.abs %>%
            </div>
            <div style="color: #868e96; font-size: 12px; margin-top: 4px;">
              Avg by today: <%= format_dollars(@expense_avg_by_today) %>
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<%# Monthly Spend Chart %>
<div style="margin-bottom: 24px;">
  <h2 style="color: #212529; font-size: 18px; margin-bottom: 12px;">Monthly Spending vs 6-Month Average</h2>
  <img src="<%= attachments['monthly_spend.png'].url %>"
       alt="Monthly spending chart showing current month vs 6-month average"
       width="600"
       style="max-width: 100%; height: auto; display: block;" />
</div>

<%# Recent Transactions %>
<div style="margin-bottom: 24px;">
  <h2 style="color: #212529; font-size: 18px; margin-bottom: 12px;">Transactions (Last 24 Hours)</h2>
  <% if @recent_transactions.any? %>
    <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 2px solid #dee2e6;">
          <th style="text-align: left; padding: 8px 8px 8px 0; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Merchant</th>
          <th style="text-align: left; padding: 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Category</th>
          <th style="text-align: right; padding: 8px 0 8px 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_transactions.each do |txn| %>
          <tr style="border-bottom: 1px solid #f1f3f5;">
            <td style="padding: 10px 8px 10px 0; color: #212529; font-size: 14px;">
              <%= txn.merchant&.custom_name.presence || txn.merchant&.merchant_name || txn.name %>
            </td>
            <td style="padding: 10px 8px; color: #868e96; font-size: 14px;">
              <%= txn.merchant_tag&.name || '—' %>
            </td>
            <td style="padding: 10px 0 10px 8px; text-align: right; font-size: 14px; font-weight: 500; color: <%= txn.transaction_type == 'income' ? '#2f9e44' : '#212529' %>;">
              <%= txn.transaction_type == 'income' ? '+' : '' %><%= format_dollars(txn.amount.abs) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #868e96; font-size: 14px;">No transactions in the last 24 hours.</p>
  <% end %>
</div>

<%# Category Spending Summary %>
<div style="margin-bottom: 24px;">
  <h2 style="color: #212529; font-size: 18px; margin-bottom: 12px;">Spending by Category</h2>
  <% if @category_spending.any? %>
    <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 2px solid #dee2e6;">
          <th style="text-align: left; padding: 8px 8px 8px 0; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Category</th>
          <th style="text-align: right; padding: 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Month to Date</th>
          <th style="text-align: right; padding: 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Budget</th>
          <th style="text-align: right; padding: 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Trend</th>
          <th style="text-align: right; padding: 8px 0 8px 8px; color: #868e96; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">% Change</th>
        </tr>
      </thead>
      <tbody>
        <% @category_spending.each do |cat| %>
          <% over_budget = cat[:budget] > 0 && cat[:trend] > cat[:budget] %>
          <tr style="border-bottom: 1px solid #f1f3f5;">
            <td style="padding: 10px 8px 10px 0; color: #212529; font-size: 14px; font-weight: 500;">
              <%= cat[:name] %>
            </td>
            <td style="padding: 10px 8px; text-align: right; color: #212529; font-size: 14px;">
              <%= format_dollars(cat[:month_to_date]) %>
            </td>
            <td style="padding: 10px 8px; text-align: right; color: #868e96; font-size: 14px;">
              <%= format_dollars(cat[:budget]) %>
            </td>
            <td style="padding: 10px 8px; text-align: right; font-size: 14px; font-weight: 500; color: <%= over_budget ? '#e03131' : '#2f9e44' %>;">
              <%= format_dollars(cat[:trend]) %>
            </td>
            <td style="padding: 10px 0 10px 8px; text-align: right; font-size: 14px; font-weight: 500; color: <%= cat[:percent_change] > 0 ? '#e03131' : '#2f9e44' %>;">
              <%= raw(cat[:percent_change] > 0 ? '&#9650;' : '&#9660;') %> <%= cat[:percent_change].abs %>%
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #868e96; font-size: 14px;">No expense transactions this month.</p>
  <% end %>
</div>
